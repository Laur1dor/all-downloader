# xray-core proxy with subscription auto-update and optional egress shaping.
FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1

# iproute2 for tc shaping; ca-certificates + unzip to fetch xray.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates iproute2 unzip curl \
    && rm -rf /var/lib/apt/lists/*

# Install the xray-core binary (pinned).
ARG XRAY_VERSION=25.6.8
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
        amd64) zip=Xray-linux-64.zip ;; \
        arm64) zip=Xray-linux-arm64-v8a.zip ;; \
        *) echo "unsupported arch $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/XTLS/Xray-core/releases/download/v${XRAY_VERSION}/${zip}" -o /tmp/xray.zip; \
    unzip -o /tmp/xray.zip xray -d /usr/local/bin; \
    chmod +x /usr/local/bin/xray; \
    rm /tmp/xray.zip; \
    mkdir -p /etc/xray

WORKDIR /app
COPY proxy/build_config.py /app/build_config.py
COPY proxy/entrypoint.sh /usr/local/bin/xray-entrypoint.sh
COPY scripts/netshape.sh /usr/local/bin/netshape.sh
RUN chmod +x /usr/local/bin/xray-entrypoint.sh /usr/local/bin/netshape.sh \
    && sed -i 's/\r$//' /usr/local/bin/xray-entrypoint.sh /usr/local/bin/netshape.sh

ENTRYPOINT ["/usr/local/bin/xray-entrypoint.sh"]
