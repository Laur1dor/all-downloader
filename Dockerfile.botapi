# telegram-bot-api with tc (traffic shaping) on top of the official image.
FROM aiogram/telegram-bot-api:latest

RUN apk add --no-cache iproute2

COPY botapi-entrypoint.sh /shaped-entrypoint.sh
RUN chmod +x /shaped-entrypoint.sh && sed -i 's/\r$//' /shaped-entrypoint.sh

ENTRYPOINT ["/shaped-entrypoint.sh"]
