# Telegram
BOT_TOKEN=123456:ABC-your-bot-token
ADMIN_ID=123456789   # your numeric Telegram user id (e.g. from @userinfobot)

# PostgreSQL
DB_NAME=mediadl
DB_USER=mediadl
DB_PASSWORD=change-me
DB_HOST=postgres
DB_PORT=5432

# Optional overrides
#HEALTH_PORT=30080
#COOKIES_FILE=data/cookies.txt
#LEGACY_DUMP_FILE=info.txt
#MAX_UPLOAD_MB=2000

# Self-hosted Bot API server for large uploads (COMPOSE_PROFILES=local-api).
# Get TELEGRAM_API_ID/HASH at https://my.telegram.org -> API development tools.
#TELEGRAM_API_ID=
#TELEGRAM_API_HASH=
#TELEGRAM_API_URL=http://telegram-bot-api:8081

# Adaptive proxy routing (COMPOSE_PROFILES=vless). The bot goes direct while a
# site is reachable and falls back to this proxy only when it is blocked.
#PROXY_URL=socks5h://xray:2080
# HTTP proxy for spotdl (Spotify's API is geo-blocked in some regions).
#SPOTDL_HTTP_PROXY=http://xray:2081
#VLESS_SUBSCRIPTION=https://example.com/sub/xxxx
#VLESS_CONFIGS=vless://...,vless://...
#VLESS_CONFIGS_FILE=data/vless.txt
#VLESS_UPDATE_INTERVAL=21600

# Enable extra services, comma-separated: local-api, vless
#COMPOSE_PROFILES=local-api,vless

# Ceilings for the admin control panel's custom speed values (Mbit/s).
#MAIN_MAX_MBIT=1000     # main uplink — caps user/admin/total-channel speeds
#VPN_MAX_MBIT=1000      # VLESS node uplink — caps the VPN-channel speed
